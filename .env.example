# Copy this to .env and fill in your values
# Then load with: source .env  (or use direnv)

# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — which model to use (defaults to Opus 4.5)
AGENT_MODEL=claude-opus-4-5-20251101

# Optional — the directory the agent operates in (defaults to cwd)
AGENT_WORKING_DIR=/path/to/your/project
